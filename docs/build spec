### 5.2 Protocol Editor (Safe-Range UI)

When the practitioner taps "Edit Protocol," they see constrained sliders for each parameter. Sliders enforce the safe envelope вҖ” they cannot be dragged outside the allowed range.

```swift
// ios/HydraScan/Components/SessionConfigEditor.swift

struct SessionConfigEditor: View {
    @Binding var config: SessionConfig
    let safeEnvelope: SafeEnvelope

    var body: some View {
        Form {
            Section("Session") {
                Stepper("Duration: \(config.edgeCycleDuration) min",
                        value: $config.edgeCycleDuration,
                        in: safeEnvelope.edgeCycleDurationMin...safeEnvelope.edgeCycleDurationMax)
            }

            Section("Thermal") {
                SafeRangeSlider(
                    label: "Hot Intensity (PWM)",
                    value: $config.pwmValues.hot[0],
                    range: Double(safeEnvelope.pwmHotMin)...Double(safeEnvelope.pwmHotMax)
                )
                SafeRangeSlider(
                    label: "Cold Intensity (PWM)",
                    value: $config.pwmValues.cold[0],
                    range: Double(safeEnvelope.pwmColdMin)...Double(safeEnvelope.pwmColdMax)
                )
                SafeRangeSlider(
                    label: "Hot Drop",
                    value: $config.hotDrop,
                    range: Double(safeEnvelope.hotDropMin)...Double(safeEnvelope.hotDropMax)
                )
            }

            Section("Vibration") {
                SafeRangeSlider(
                    label: "Min Vibration",
                    value: $config.vibMin,
                    range: Double(safeEnvelope.vibMinFloor)...Double(safeEnvelope.vibMinCeiling)
                )
                SafeRangeSlider(
