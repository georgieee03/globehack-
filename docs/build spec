## Phase 1: Identity, Auth & Multi-Tenant Backend

> **Goal:** Users can sign in, be assigned to a clinic, and have role-based access. The Hydrawav3 API auth flow is proxied through the backend.
> **Owner:** Backend agent + iOS agent (auth UI)
> **Estimated time:** 3вҖ“4 hours
> **Dependencies:** Phase 0
> **Judging impact:** Platform Integration (20pts), Technical Feasibility (20pts)

### 1.1 Supabase Auth Configuration

**Auth providers to enable:**
- Email (magic link)
- Apple (Sign in with Apple вҖ” required for App Store submission)
- Google (optional)

**Implementation:**

```typescript
// backend/supabase/functions/hydrawav-auth/index.ts

import { serve } from 'https://deno.land/std@0.177.0/http/server.ts'

// This function proxies login to the Hydrawav3 API and stores the JWT
// so the backend can make MQTT calls on behalf of the clinic

interface HydrawavLoginResponse {
  JWT_REFRESH_TOKEN: string;
  JWT_ACCESS_TOKEN: string;
}

serve(async (req) => {
  const { username, password } = await req.json();

  // Call Hydrawav3 auth endpoint
  const hwResponse = await fetch(`${Deno.env.get('HYDRAWAV_API_BASE_URL')}/api/v1/auth/login`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ username, password, rememberMe: true }),
  });

  if (!hwResponse.ok) {
    return new Response(JSON.stringify({ error: 'Hydrawav3 auth failed' }), { status: 401 });
  }

  const tokens: HydrawavLoginResponse = await hwResponse.json();

  // Store tokens securely in Supabase (encrypted at rest)
  // These are clinic-level credentials, not per-user
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  );

  // Upsert clinic's Hydrawav3 credentials
  await supabase.from('clinic_hw_tokens').upsert({
    clinic_id: req.headers.get('x-clinic-id'),
    access_token: tokens.JWT_ACCESS_TOKEN,
    refresh_token: tokens.JWT_REFRESH_TOKEN,
    updated_at: new Date().toISOString(),
  });

  return new Response(JSON.stringify({ success: true }), { status: 200 });
});
```

### 1.2 iOS Auth Flow

```swift
// ios/HydraScan/Services/AuthService.swift

import Supabase
import AuthenticationServices  // Sign in with Apple

class AuthService: ObservableObject {
    @Published var currentUser: User?
    @Published var isAuthenticated = false

    private let supabase: SupabaseClient

    init() {
        self.supabase = SupabaseClient(
            supabaseURL: URL(string: Config.supabaseURL)!,
            supabaseKey: Config.supabaseAnonKey
        )
    }

    // Sign in with Apple
    func signInWithApple(credential: ASAuthorizationAppleIDCredential) async throws {
        guard let identityToken = credential.identityToken,
              let tokenString = String(data: identityToken, encoding: .utf8) else {
            throw AuthError.invalidCredential
        }

        let session = try await supabase.auth.signInWithIdToken(
            credentials: .init(provider: .apple, idToken: tokenString)
        )

        // Fetch or create user profile
        await loadUserProfile(authId: session.user.id)
    }

    // Email magic link
    func signInWithEmail(_ email: String) async throws {
        try await supabase.auth.signInWithOTP(email: email)
    }

    // Verify OTP
    func verifyOTP(email: String, token: String) async throws {
        let session = try await supabase.auth.verifyOTP(
            email: email, token: token, type: .magiclink
        )
        await loadUserProfile(authId: session.user.id)
    }

    private func loadUserProfile(authId: UUID) async {
        do {
            let user: User = try await supabase.from("users")
                .select()
                .eq("id", value: authId.uuidString)
                .single()
                .execute()
                .value
            self.currentUser = user
            self.isAuthenticated = true
        } catch {
            // User doesn't exist yet вҖ” needs onboarding
            self.isAuthenticated = false
        }
    }
}
```

