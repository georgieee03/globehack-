### 7.3 Outcome вҶ’ Recovery Graph Update

```typescript
// backend/supabase/functions/trend-analyzer/index.ts

async function updateRecoveryGraph(
  sessionId: string,
  outcome: Outcome,
  sessionConfig: SessionConfig,
  supabase: SupabaseClient
) {
  const session = await supabase.from('sessions').select('*').eq('id', sessionId).single();

  // 1. Store stiffness delta as a data point
  if (outcome.stiffness_before != null && outcome.stiffness_after != null) {
    await supabase.from('recovery_graph').insert({
      client_id: session.data.client_id,
      body_region: session.data.session_config.targetRegion || 'general',
      metric_type: 'stiffness',
      value: outcome.stiffness_after,
      source: 'session_outcome',
      source_id: sessionId,
    });
  }

  // 2. Store ROM delta if re-tested
  if (outcome.rom_after) {
    for (const [key, afterValue] of Object.entries(outcome.rom_after)) {
      await supabase.from('recovery_graph').insert({
        client_id: session.data.client_id,
        body_region: extractRegionFromRomKey(key),
        metric_type: `rom_${key}`,
        value: afterValue as number,
        source: 'session_outcome',
        source_id: sessionId,
      });
    }
  }

  // 3. Compute and store updated Recovery Score
  const newScore = await computeRecoveryScore(session.data.client_id, supabase);
  await supabase.from('recovery_graph').insert({
    client_id: session.data.client_id,
    body_region: 'general',
    metric_type: 'recovery_score',
    value: newScore,
    source: 'session_outcome',
    source_id: sessionId,
  });
}
```

### 7.4 Plateau / Escalation Detection

```typescript
// If outcomes are flat over several sessions, flag for practitioner review

async function detectPlateau(clientId: string, bodyRegion: string, supabase: SupabaseClient): Promise<boolean> {
  const { data: recentScores } = await supabase
    .from('recovery_graph')
    .select('value')
    .eq('client_id', clientId)
    .eq('body_region', bodyRegion)
    .eq('metric_type', 'stiffness')
    .order('recorded_at', { ascending: false })
    .limit(3);

  if (!recentScores || recentScores.length < 3) return false;

  // Check if stiffness hasn't changed by more than 1 point across last 3 sessions
  const values = recentScores.map(s => s.value);
  const range = Math.max(...values) - Math.min(...values);
  return range <= 1;  // Plateau if range is вүӨ1 across 3 sessions
}
```

