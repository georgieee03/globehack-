### C.2 UI String Validation

```typescript
// shared/constants/language-guardrails.ts

const FORBIDDEN_TERMS = [
  'diagnos', 'treat', 'cure', 'medical device', 'clinical',
  'prescription', 'medication', 'drug', 'heal', 'therapy',
  'patient' /* use 'client' instead */,
  'reduces inflammation', 'we heal',
];

const PREFERRED_REPLACEMENTS: Record<string, string> = {
  'patient': 'client',
  'diagnosis': 'assessment',
  'treatment': 'session',
  'therapy': 'recovery support',
  'clinical': 'wellness',
  'medical': 'recovery',
  'cure': 'support',
  'heal': 'recover',
};

function validateWellnessLanguage(text: string): { valid: boolean; violations: string[] } {
  const violations: string[] = [];
  const lower = text.toLowerCase();
  for (const term of FORBIDDEN_TERMS) {
    if (lower.includes(term)) {
      violations.push(`Found forbidden term: "${term}". Use: "${PREFERRED_REPLACEMENTS[term] || 'see guidelines'}"`);
    }
  }
  return { valid: violations.length === 0, violations };
}
```

