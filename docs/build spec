## 6. Data Model & Schema Definitions

### 6.1 Core Tables

#### `clinics`
```sql
CREATE TABLE clinics (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name          TEXT NOT NULL,
  address       TEXT,
  timezone      TEXT DEFAULT 'America/Phoenix',
  created_at    TIMESTAMPTZ DEFAULT now(),
  updated_at    TIMESTAMPTZ DEFAULT now()
);
```

#### `users`
```sql
CREATE TABLE users (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  clinic_id     UUID REFERENCES clinics(id) NOT NULL,
  role          TEXT NOT NULL CHECK (role IN ('client', 'practitioner', 'admin')),
  email         TEXT UNIQUE,
  full_name     TEXT NOT NULL,
  phone         TEXT,
  date_of_birth DATE,               -- NULL for practitioners/admins
  auth_provider TEXT,                -- 'apple', 'google', 'email', 'sms'
  avatar_url    TEXT,
  created_at    TIMESTAMPTZ DEFAULT now(),
  updated_at    TIMESTAMPTZ DEFAULT now()
);

-- RLS: users can only see users in their own clinic
CREATE POLICY clinic_isolation ON users
  USING (clinic_id = (SELECT clinic_id FROM users WHERE id = auth.uid()));
```

#### `devices` (Device Registry)
```sql
CREATE TABLE devices (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  clinic_id             UUID REFERENCES clinics(id) NOT NULL,
  device_mac            TEXT NOT NULL,                          -- e.g. '74:4D:BD:A0:A3:EC'
  label                 TEXT NOT NULL,                          -- e.g. 'Room 2 вҖ” Recovery Bay'
  room                  TEXT,
  assigned_practitioner UUID REFERENCES users(id),
  status                TEXT DEFAULT 'idle'
                        CHECK (status IN ('idle', 'in_session', 'paused', 'maintenance', 'offline')),
  last_session_id       UUID,
  firmware              TEXT,
  created_at            TIMESTAMPTZ DEFAULT now(),
  updated_at            TIMESTAMPTZ DEFAULT now(),
  UNIQUE(clinic_id, device_mac)
);
```

#### `client_profiles`
```sql
CREATE TABLE client_profiles (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id       UUID REFERENCES users(id) NOT NULL UNIQUE,
  clinic_id     UUID REFERENCES clinics(id) NOT NULL,

  -- Recovery signals (updated each intake)
  primary_regions     JSONB DEFAULT '[]',       -- e.g. ["right_shoulder", "lower_back"]
  recovery_signals    JSONB DEFAULT '{}',       -- e.g. {"right_shoulder": {"type": "stiffness", "severity": 7, "trigger": "after_running"}}
  goals               TEXT[],                   -- e.g. ['mobility', 'warm_up', 'recovery']
  activity_context    TEXT,                     -- e.g. 'marathon_runner', 'desk_worker'
  sensitivities       TEXT[],                   -- e.g. ['first_time', 'heat_sensitive']
  notes               TEXT,

  -- Wearable context (last sync)
  wearable_hrv        NUMERIC,
  wearable_strain     NUMERIC,
  wearable_sleep_score NUMERIC,
  wearable_last_sync  TIMESTAMPTZ,

  created_at          TIMESTAMPTZ DEFAULT now(),
  updated_at          TIMESTAMPTZ DEFAULT now()
);
```

#### `assessments`
```sql
CREATE TABLE assessments (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  client_id       UUID REFERENCES client_profiles(id) NOT NULL,
  clinic_id       UUID REFERENCES clinics(id) NOT NULL,
  practitioner_id UUID REFERENCES users(id),
  assessment_type TEXT NOT NULL CHECK (assessment_type IN ('intake', 'pre_session', 'follow_up', 'reassessment')),

  -- QuickPose data
  quickpose_data  JSONB,            -- Full pose/ROM/angle/asymmetry output
  rom_values      JSONB,            -- e.g. {"right_shoulder_flexion": 142, "left_shoulder_flexion": 158}
  asymmetry_scores JSONB,           -- e.g. {"shoulder_flexion": 10.1, "hip_rotation": 3.2}
  movement_quality_scores JSONB,    -- e.g. {"squat": 0.82, "hip_hinge": 0.71}
  gait_metrics    JSONB,            -- e.g. {"cadence": 112, "step_symmetry": 0.94}

  -- Vitals (if captured)
  heart_rate      NUMERIC,
  breath_rate     NUMERIC,
  hrv_rmssd       NUMERIC,

  -- Recovery signals (snapshot at time of assessment)
  body_zones      JSONB,            -- Highlighted zones with signals
  recovery_goal   TEXT,
  subjective_baseline JSONB,        -- e.g. {"stiffness": 7, "soreness": 4, "mobility": 3}

  -- Computed
  recovery_map    JSONB,            -- The 60-second Recovery Map output
  recovery_graph_delta JSONB,       -- Changes to the Recovery Graph

  created_at      TIMESTAMPTZ DEFAULT now()
);
```

#### `sessions`
```sql
CREATE TABLE sessions (
  id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  client_id         UUID REFERENCES client_profiles(id) NOT NULL,
  clinic_id         UUID REFERENCES clinics(id) NOT NULL,
  practitioner_id   UUID REFERENCES users(id) NOT NULL,
  device_id         UUID REFERENCES devices(id) NOT NULL,
  assessment_id     UUID REFERENCES assessments(id),

  -- The exact SessionConfig that was sent to the device
  session_config    JSONB NOT NULL,

  -- Recommendation metadata
  recommended_config  JSONB,        -- What the engine originally suggested
  practitioner_edits  JSONB,        -- What the practitioner changed
  recommendation_rationale TEXT,    -- LLM-generated explanation
  confidence_score  NUMERIC,        -- 0.0 to 1.0

  -- Lifecycle
  status            TEXT DEFAULT 'pending'
                    CHECK (status IN ('pending', 'active', 'paused', 'completed', 'cancelled', 'error')),
  started_at        TIMESTAMPTZ,
  paused_at         TIMESTAMPTZ,
  resumed_at        TIMESTAMPTZ,
  completed_at      TIMESTAMPTZ,
  total_duration_s  INTEGER,

  -- Post-session
  outcome           JSONB,          -- See outcomes schema below
  practitioner_notes TEXT,
  retest_values     JSONB,

  created_at        TIMESTAMPTZ DEFAULT now(),
  updated_at        TIMESTAMPTZ DEFAULT now()
);
```

#### `outcomes`
```sql
CREATE TABLE outcomes (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  session_id      UUID REFERENCES sessions(id) NOT NULL,
  client_id       UUID REFERENCES client_profiles(id) NOT NULL,
  recorded_by     TEXT NOT NULL CHECK (recorded_by IN ('client', 'practitioner')),

  -- Subjective outcomes
  stiffness_before    INTEGER CHECK (stiffness_before BETWEEN 0 AND 10),
  stiffness_after     INTEGER CHECK (stiffness_after BETWEEN 0 AND 10),
  soreness_before     INTEGER CHECK (soreness_before BETWEEN 0 AND 10),
  soreness_after      INTEGER CHECK (soreness_after BETWEEN 0 AND 10),
  mobility_improved   BOOLEAN,
  session_effective   BOOLEAN,
  readiness_improved  BOOLEAN,
  repeat_intent       TEXT CHECK (repeat_intent IN ('yes', 'maybe', 'no')),

  -- Objective outcomes (if re-tested)
  rom_after           JSONB,        -- Post-session ROM values
  rom_delta           JSONB,        -- Computed difference from assessment ROM

  -- Free text
  client_notes        TEXT,
  practitioner_notes  TEXT,

  created_at          TIMESTAMPTZ DEFAULT now()
);
```

#### `recovery_graph`
```sql
CREATE TABLE recovery_graph (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  client_id       UUID REFERENCES client_profiles(id) NOT NULL,
  body_region     TEXT NOT NULL,    -- e.g. 'right_shoulder', 'lower_back', 'left_hip'
  metric_type     TEXT NOT NULL,    -- e.g. 'rom_flexion', 'stiffness', 'asymmetry', 'recovery_score'
  value           NUMERIC NOT NULL,
  source          TEXT NOT NULL,    -- 'assessment', 'session_outcome', 'daily_checkin', 'wearable'
  source_id       UUID,            -- Reference to assessment, session, or checkin
  recorded_at     TIMESTAMPTZ DEFAULT now()
);

-- Index for fast client + region + time queries
CREATE INDEX idx_recovery_graph_client_region
  ON recovery_graph(client_id, body_region, recorded_at DESC);
```

#### `daily_checkins`
```sql
CREATE TABLE daily_checkins (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  client_id       UUID REFERENCES client_profiles(id) NOT NULL,
  checkin_type    TEXT NOT NULL CHECK (checkin_type IN ('daily', 'post_activity', 'pre_visit')),

  -- Signals
  overall_feeling   INTEGER CHECK (overall_feeling BETWEEN 1 AND 5),
  target_regions    JSONB,          -- Body regions with current status
  activity_since_last TEXT,         -- What they did since last checkin
  recovery_score    NUMERIC,        -- Computed

  created_at        TIMESTAMPTZ DEFAULT now()
);
```

### 6.2 TypeScript Types (shared between iOS bridge and backend)

```typescript
// === Core enums ===

type UserRole = 'client' | 'practitioner' | 'admin';
type DeviceStatus = 'idle' | 'in_session' | 'paused' | 'maintenance' | 'offline';
type SessionStatus = 'pending' | 'active' | 'paused' | 'completed' | 'cancelled' | 'error';
type AssessmentType = 'intake' | 'pre_session' | 'follow_up' | 'reassessment';
type RecoveryGoal = 'mobility' | 'warm_up' | 'recovery' | 'relaxation' | 'performance_prep';
type RecoverySignalType = 'stiffness' | 'soreness' | 'tightness' | 'restriction' | 'guarding';
type ActivityTrigger = 'morning' | 'after_running' | 'after_lifting' | 'post_travel' | 'post_training' | 'evening' | 'general';

// === Body regions ===

type BodyRegion =
  | 'right_shoulder' | 'left_shoulder'
  | 'right_hip' | 'left_hip'
  | 'lower_back' | 'upper_back'
  | 'right_knee' | 'left_knee'
  | 'neck'
  | 'right_calf' | 'left_calf'
  | 'right_arm' | 'left_arm'
  | 'right_foot' | 'left_foot';

// === Recovery signal ===

interface RecoverySignal {
  region: BodyRegion;
  type: RecoverySignalType;
  severity: number;          // 1вҖ“10
  trigger: ActivityTrigger;
  notes?: string;
}

// === QuickPose output ===

interface QuickPoseResult {
  landmarks: Array<{ x: number; y: number; z: number; visibility: number }>;  // 33 points
  jointAngles: Record<string, number>;      // e.g. { "right_shoulder_flexion": 142 }
  romValues: Record<string, number>;        // Same structure, normalized to ROM
  asymmetryScores: Record<string, number>;  // e.g. { "shoulder_flexion": 10.1 }
  movementQuality: Record<string, number>;  // e.g. { "squat": 0.82 }
  gaitMetrics?: {
    cadence: number;
    stepSymmetry: number;
    stepLength: number;
  };
  capturedAt: string;  // ISO 8601
}

// === Recovery Map ===

interface RecoveryMap {
  clientId: string;
  highlightedRegions: Array<{
    region: BodyRegion;
    severity: number;
    signalType: RecoverySignalType;
    romDelta?: number;          // Compared to last assessment
    asymmetryFlag: boolean;
    compensationHint?: string;  // e.g. "Likely compensating from lower back"
  }>;
  wearableContext?: {
    hrv: number;
    strain: number;
    sleepScore: number;
    lastSync: string;
  };
  priorSessions: Array<{
    date: string;
    config: SessionConfigSummary;
    outcomeRating: number;
  }>;
  suggestedGoal: RecoveryGoal;
  generatedAt: string;
}

// === SessionConfig (for MQTT API) ===

type ModalityFunc =
  | 'leftColdBlue' | 'leftHotRed'
  | 'rightColdBlue' | 'rightHotRed';

type PlayCmd = 1 | 2 | 3 | 4;  // 1=Start, 2=Pause, 3=Stop, 4=Resume

interface SessionConfig {
  // Device addressing
  mac: string;                     // e.g. "74:4D:BD:A0:A3:EC"

  // Session envelope
  sessionCount: number;
  sessionPause: number;
  sDelay: number;

  // Cycle choreography
  cycle1: number;
  cycle5: number;
  edgeCycleDuration: number;       // minutes; 9 = standard session
  cycleRepetitions: number[];
  cycleDurations: number[];
  cyclePauses: number[];
  pauseIntervals: number[];

  // Per-pad modality sequences
  leftFuncs: ModalityFunc[];
  rightFuncs: ModalityFunc[];

  // Thermal intensity arrays (PWM)
  pwmValues: {
    hot: [number, number, number];
    cold: [number, number, number];
  };

  // Lifecycle
  playCmd: PlayCmd;
  led: 0 | 1;                     // Photobiomodulation toggle

  // Thermal contrast & vibration
  hotDrop: number;
  coldDrop: number;
  vibMin: number;
  vibMax: number;

  // Computed
  totalDuration: number;           // seconds
}

// === Safe Envelope ===

interface SafeEnvelope {
  pwmHotMin: number;       pwmHotMax: number;
  pwmColdMin: number;      pwmColdMax: number;
  vibMinFloor: number;     vibMinCeiling: number;
  vibMaxFloor: number;     vibMaxCeiling: number;
  hotDropMin: number;      hotDropMax: number;
  coldDropMin: number;     coldDropMax: number;
  edgeCycleDurationMin: number;  edgeCycleDurationMax: number;
}

// Region-specific overrides
const SAFE_ENVELOPES: Record<string, Partial<SafeEnvelope>> = {
  _default: {
    pwmHotMin: 30, pwmHotMax: 150,
    pwmColdMin: 100, pwmColdMax: 255,
    vibMinFloor: 10, vibMinCeiling: 50,
    vibMaxFloor: 100, vibMaxCeiling: 255,
    hotDropMin: 1, hotDropMax: 10,
    coldDropMin: 1, coldDropMax: 10,
    edgeCycleDurationMin: 5, edgeCycleDurationMax: 15,
  },
  neck: {
    pwmHotMax: 100,       // Tighter cap for sensitive region
    vibMaxCeiling: 180,
  },
  lower_back: {
    pwmHotMax: 120,
    vibMaxCeiling: 200,
  }
};
```

