### 4.4 History Scorer

```typescript
// backend/supabase/functions/recovery-engine/history-scorer.ts

interface HistoryScore {
  bestConfig: Partial<SessionConfig> | null;
  outcomeAverage: number;
  sessionCount: number;
  confidence: number;           // 0.0 (no history) to 1.0 (strong prior evidence)
  adjustments: string[];        // e.g. ["Reduced intensity based on last 2 sessions"]
}

async function scoreHistory(
  clientId: string,
  targetRegion: BodyRegion,
  goal: RecoveryGoal,
  supabase: SupabaseClient
): Promise<HistoryScore> {

  // Fetch last 5 sessions for this client + region + goal
  const { data: sessions } = await supabase
    .from('sessions')
    .select('session_config, outcome:outcomes(*)')
    .eq('client_id', clientId)
    .eq('status', 'completed')
    .order('completed_at', { ascending: false })
    .limit(5);

  if (!sessions || sessions.length === 0) {
    return {
      bestConfig: null,
      outcomeAverage: 0,
      sessionCount: 0,
      confidence: 0.0,
      adjustments: ['No prior sessions вҖ” using default protocol for this goal.'],
    };
  }

  // Score each session by outcome effectiveness
  const scored = sessions.map(s => {
    const outcome = s.outcome?.[0];
    if (!outcome) return { config: s.session_config, score: 0.5 };

    let score = 0;
    if (outcome.mobility_improved) score += 0.3;
    if (outcome.session_effective) score += 0.3;
    if (outcome.stiffness_after < outcome.stiffness_before) score += 0.2;
    if (outcome.repeat_intent === 'yes') score += 0.2;

    return { config: s.session_config, score };
  });

  // Find best-performing config
  scored.sort((a, b) => b.score - a.score);
  const best = scored[0];

  const avgScore = scored.reduce((sum, s) => sum + s.score, 0) / scored.length;

  return {
    bestConfig: best.config,
    outcomeAverage: avgScore,
    sessionCount: sessions.length,
    confidence: Math.min(1.0, sessions.length * 0.2),  // 5+ sessions = 1.0 confidence
    adjustments: generateAdjustments(scored),
  };
}
```

