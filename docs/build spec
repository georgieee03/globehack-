### 2.2 MQTT Proxy Function

This is the critical integration point. The backend proxies MQTT commands to the Hydrawav3 API, handling auth, serialization, and logging.

```typescript
// backend/supabase/functions/hydrawav-mqtt/index.ts

import { serve } from 'https://deno.land/std@0.177.0/http/server.ts'
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

interface MqttPublishRequest {
  clinicId: string;
  deviceId: string;
  sessionConfig: SessionConfig;
  command: 'start' | 'pause' | 'resume' | 'stop';
}

serve(async (req) => {
  const supabase = createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!
  );

  const { clinicId, deviceId, sessionConfig, command } = await req.json() as MqttPublishRequest;

  // 1. Fetch clinic's Hydrawav3 JWT token
  const { data: tokenData } = await supabase
    .from('clinic_hw_tokens')
    .select('access_token')
    .eq('clinic_id', clinicId)
    .single();

  if (!tokenData?.access_token) {
    return new Response(JSON.stringify({ error: 'No Hydrawav3 credentials for this clinic' }), { status: 401 });
  }

  // 2. Fetch device MAC from registry
  const { data: device } = await supabase
    .from('devices')
    .select('device_mac, status')
    .eq('id', deviceId)
    .eq('clinic_id', clinicId)
    .single();

  if (!device) {
    return new Response(JSON.stringify({ error: 'Device not found' }), { status: 404 });
  }

  // 3. Build the MQTT payload
  let payload: Record<string, any>;

  switch (command) {
    case 'start':
      // Validate against safe envelope FIRST
      const validation = validateSafeEnvelope(sessionConfig);
      if (!validation.valid) {
        return new Response(JSON.stringify({
          error: 'SessionConfig outside safe envelope',
          violations: validation.violations
        }), { status: 400 });
      }
      payload = { ...sessionConfig, mac: device.device_mac, playCmd: 1 };
      break;
    case 'pause':
      payload = { mac: device.device_mac, playCmd: 2 };
      break;
    case 'stop':
      payload = { mac: device.device_mac, playCmd: 3 };
      break;
    case 'resume':
      payload = { mac: device.device_mac, playCmd: 4 };
      break;
    default:
      return new Response(JSON.stringify({ error: 'Invalid command' }), { status: 400 });
  }

  // 4. CRITICAL: Stringify the payload (Hydrawav3 API requires string, not object)
  const stringifiedPayload = JSON.stringify(payload);

  // 5. Publish to Hydrawav3 MQTT API
  const mqttResponse = await fetch(
    `${Deno.env.get('HYDRAWAV_API_BASE_URL')}/api/v1/mqtt/publish`,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': tokenData.access_token,  // Already "Bearer <token>"
      },
      body: JSON.stringify({
        topic: 'HydraWav3Pro/config',
        payload: stringifiedPayload,
      }),
    }
  );

  // 6. Update device status in registry
  const newStatus = {
    start: 'in_session',
    pause: 'paused',
    resume: 'in_session',
    stop: 'idle',
  }[command];

  await supabase
    .from('devices')
    .update({ status: newStatus, updated_at: new Date().toISOString() })
    .eq('id', deviceId);

  // 7. Log the command for audit trail
  await supabase.from('mqtt_command_log').insert({
    clinic_id: clinicId,
    device_id: deviceId,
    command,
    payload: payload,
    mqtt_response_status: mqttResponse.status,
    created_at: new Date().toISOString(),
  });

  if (!mqttResponse.ok) {
    const errorBody = await mqttResponse.text();
    return new Response(JSON.stringify({
      error: 'MQTT publish failed',
      status: mqttResponse.status,
      detail: errorBody,
    }), { status: 502 });
  }

  return new Response(JSON.stringify({
    success: true,
    command,
    deviceMac: device.device_mac,
    newStatus,
  }), { status: 200 });
});

// Safe envelope validation
function validateSafeEnvelope(config: SessionConfig): { valid: boolean; violations: string[] } {
  const violations: string[] = [];
  const envelope = SAFE_ENVELOPES._default;

  // PWM hot values
  for (const v of config.pwmValues.hot) {
    if (v < envelope.pwmHotMin || v > envelope.pwmHotMax) {
      violations.push(`pwmValues.hot value ${v} outside range [${envelope.pwmHotMin}, ${envelope.pwmHotMax}]`);
    }
  }

  // PWM cold values
  for (const v of config.pwmValues.cold) {
    if (v < envelope.pwmColdMin || v > envelope.pwmColdMax) {
      violations.push(`pwmValues.cold value ${v} outside range [${envelope.pwmColdMin}, ${envelope.pwmColdMax}]`);
    }
  }

  // Vibration
  if (config.vibMin < envelope.vibMinFloor || config.vibMin > envelope.vibMinCeiling) {
    violations.push(`vibMin ${config.vibMin} outside range [${envelope.vibMinFloor}, ${envelope.vibMinCeiling}]`);
  }
  if (config.vibMax < envelope.vibMaxFloor || config.vibMax > envelope.vibMaxCeiling) {
    violations.push(`vibMax ${config.vibMax} outside range [${envelope.vibMaxFloor}, ${envelope.vibMaxCeiling}]`);
  }

  // Duration
  if (config.edgeCycleDuration < envelope.edgeCycleDurationMin || config.edgeCycleDuration > envelope.edgeCycleDurationMax) {
    violations.push(`edgeCycleDuration ${config.edgeCycleDuration} outside range [${envelope.edgeCycleDurationMin}, ${envelope.edgeCycleDurationMax}]`);
  }

  return { valid: violations.length === 0, violations };
}
```

