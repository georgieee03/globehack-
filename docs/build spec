### 3.3 Assessment Computation

```swift
// ios/HydraScan/Services/QuickPoseService.swift

class QuickPoseService {

    /// Compute ROM values from raw landmark data
    static func computeROM(landmarks: [[Landmark]]) -> [String: Double] {
        var rom: [String: Double] = [:]

        // Shoulder flexion: angle between upper arm and torso
        // Use landmarks: shoulder, elbow, hip
        rom["right_shoulder_flexion"] = maxAngle(
            landmarks: landmarks,
            jointA: .rightShoulder, jointB: .rightElbow, reference: .rightHip
        )
        rom["left_shoulder_flexion"] = maxAngle(
            landmarks: landmarks,
            jointA: .leftShoulder, jointB: .leftElbow, reference: .leftHip
        )

        // Knee flexion: angle between thigh and shin
        rom["right_knee_flexion"] = minAngle(
            landmarks: landmarks,
            jointA: .rightHip, jointB: .rightKnee, jointC: .rightAnkle
        )
        rom["left_knee_flexion"] = minAngle(
            landmarks: landmarks,
            jointA: .leftHip, jointB: .leftKnee, jointC: .leftAnkle
        )

        // Hip flexion: angle between torso and thigh
        rom["right_hip_flexion"] = maxAngle(
            landmarks: landmarks,
            jointA: .rightShoulder, jointB: .rightHip, jointC: .rightKnee
        )

        return rom
    }

    /// Compute asymmetry scores
    static func computeAsymmetry(rom: [String: Double]) -> [String: Double] {
        var asymmetry: [String: Double] = [:]

        let pairs: [(String, String, String)] = [
            ("right_shoulder_flexion", "left_shoulder_flexion", "shoulder_flexion"),
            ("right_knee_flexion", "left_knee_flexion", "knee_flexion"),
            ("right_hip_flexion", "left_hip_flexion", "hip_flexion"),
        ]

        for (right, left, name) in pairs {
            if let r = rom[right], let l = rom[left] {
                let avg = (r + l) / 2.0
                if avg > 0 {
                    asymmetry[name] = abs(r - l) / avg * 100.0  // Percentage difference
                }
            }
        }

        return asymmetry
    }

    /// Compute angle between three landmarks (in degrees)
    private static func computeAngle(a: CGPoint, b: CGPoint, c: CGPoint) -> Double {
        let ba = CGPoint(x: a.x - b.x, y: a.y - b.y)
        let bc = CGPoint(x: c.x - b.x, y: c.y - b.y)
        let dot = ba.x * bc.x + ba.y * bc.y
        let magBA = sqrt(ba.x * ba.x + ba.y * ba.y)
        let magBC = sqrt(bc.x * bc.x + bc.y * bc.y)
        let cosAngle = dot / (magBA * magBC)
        return acos(max(-1, min(1, cosAngle))) * 180.0 / .pi
    }
}
```

