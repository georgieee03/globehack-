        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
    </dependencies>
    <scenes>
        <!--Launch Screen View Controller-->
        <scene sceneID="LaunchScene">
            <objects>
                <viewController id="LaunchScreenViewController" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="LaunchRootView">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="HydraWordmarkReversed" translatesAutoresizingMaskIntoConstraints="NO" id="LaunchWordmark">
                                <rect key="frame" x="54" y="160" width="285" height="60"/>
                                <constraints>
                                    <constraint firstAttribute="height" constant="60" id="LaunchWordmarkHeight"/>
                                </constraints>
