                            <constraint firstItem="LaunchLogo" firstAttribute="centerX" secondItem="LaunchSafeArea" secondAttribute="centerX" id="LaunchLogoCenterX"/>
                            <constraint firstItem="LaunchLogo" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="LaunchSafeArea" secondAttribute="leading" constant="32" id="LaunchLogoLeading"/>
                            <constraint firstItem="LaunchSafeArea" firstAttribute="trailing" relation="greaterThanOrEqual" secondItem="LaunchLogo" secondAttribute="trailing" constant="32" id="LaunchLogoTrailing"/>
                        </constraints>
                    </view>
