                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="HydraEmblemReversed" translatesAutoresizingMaskIntoConstraints="NO" id="LaunchEmblem">
                                <rect key="frame" x="164.5" y="256" width="64" height="64"/>
